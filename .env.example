# Airtable credentials
# Copy this file to .env and fill in your values

# Your Airtable Personal Access Token
# Get it at: https://airtable.com/create/tokens
AIRTABLE_API_KEY=your_personal_access_token_here

# Your Airtable Base ID (starts with "app...")
# Find it in the URL: airtable.com/appXXXXXX/...
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# Name of your Reps table (default: Reps)
# Change this if your table has a different name
REPS_TABLE=Reps
